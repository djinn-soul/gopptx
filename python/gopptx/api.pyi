from collections.abc import Iterator
from types import TracebackType

from typing_extensions import Self

from .schemas import (
    Author,
    BatchCommand,
    BatchItemResult,
    ChartDataUpdate,
    ChartSelector,
    Comment,
    CoreProperties,
    Hyperlink,
    ImageCrop,
    ImageMetadata,
    PresentationMetadata,
    Section,
    Shape,
    ShapeProps,
    ShapeSearchQuery,
    ShapeSearchResult,
    ShapeUpdate,
    SlideChartRef,
    SlideLayoutInfo,
    SlideMasterCloneResult,
    SlideMetadata,
    TableCellInfo,
    TableInfo,
    TextFrame,
    TextRun,
)

class GopptxError(Exception):
    code: str | None
    def __init__(self, message: str, code: str | None = None) -> None: ...

class Cell:
    row: int
    col: int
    @property
    def is_merge_origin(self) -> bool: ...
    @property
    def is_spanned(self) -> bool: ...
    @property
    def row_span(self) -> int: ...
    @property
    def col_span(self) -> int: ...
    @property
    def text(self) -> str: ...
    @text.setter
    def text(self, value: str) -> None: ...
    def split(self) -> None: ...

class CellRange:
    def merge(self) -> None: ...

class Table:
    @property
    def row_count(self) -> int: ...
    @property
    def col_count(self) -> int: ...
    def __getitem__(self, idx: tuple[int | slice, int | slice]) -> Cell | CellRange: ...
    def cell(self, row: int, col: int) -> Cell: ...
    def iter_cells(self) -> Iterator[Cell]: ...
    @property
    def has_header_row(self) -> bool: ...
    @has_header_row.setter
    def has_header_row(self, value: bool) -> None: ...
    @property
    def has_banded_rows(self) -> bool: ...
    @has_banded_rows.setter
    def has_banded_rows(self, value: bool) -> None: ...

class Slide:
    def __init__(self, presentation: Presentation, metadata: SlideMetadata) -> None: ...
    @property
    def index(self) -> int: ...
    @property
    def slide_id(self) -> int: ...
    @property
    def title(self) -> str: ...
    @title.setter
    def title(self, value: str) -> None: ...
    @property
    def notes(self) -> str: ...
    @notes.setter
    def notes(self, value: str) -> None: ...
    def add_shape(
        self,
        shape_type: str,
        bounds: tuple[float, float, float, float],
        *,
        text: str = "",
        runs: list[TextRun] | None = None,
        text_frame: TextFrame | None = None,
        click_action: Hyperlink | None = None,
        **kwargs: str | ShapeProps,
    ) -> int: ...
    def add_table(
        self, rows: int, cols: int, bounds: tuple[int, int, int, int]
    ) -> int: ...
    def get_table(self, shape_id: int) -> TableInfo: ...
    def table(self, shape_id: int) -> Table: ...
    def set_table_flags(self, shape_id: int, flags: dict[str, bool]) -> None: ...
    def set_table_cell_text(
        self, shape_id: int, row: int, col: int, text: str
    ) -> None: ...
    def get_table_cell(self, shape_id: int, row: int, col: int) -> TableCellInfo: ...
    def merge_table_cells(
        self, shape_id: int, cell_range: tuple[int, int, int, int]
    ) -> None: ...
    def split_table_cell(self, shape_id: int, row: int, col: int) -> None: ...
    def add_image(
        self, path: str, bounds: tuple[float, float, float, float]
    ) -> int: ...
    def remove_shape(self, shape_id: int) -> None: ...
    def update_shape(self, shape_id: int, updates: ShapeUpdate) -> None: ...
    def list_shapes(self) -> list[Shape]: ...
    def list_charts(self) -> list[SlideChartRef]: ...
    def add_chart(
        self,
        chart_type: str,
        categories: list[str],
        values_or_series: list[float] | list[dict[str, str | list[float]]],
        **kwargs: str | tuple[float, float, float, float],
    ) -> int: ...
    def update(
        self,
        title: str | None = None,
        layout: str | None = None,
        bullets: list[str] | None = None,
    ) -> None: ...
    def remove(self) -> None: ...
    def duplicate(self, insert_at: int | None = None) -> Slide: ...

class SlideLayout:
    @property
    def part(self) -> str: ...
    @property
    def name(self) -> str: ...
    @property
    def slide_master(self) -> SlideMaster: ...

class SlideLayouts:
    def __len__(self) -> int: ...
    def __getitem__(self, idx: int) -> SlideLayout: ...
    def __iter__(self) -> Iterator[SlideLayout]: ...
    def get_by_name(self, name: str) -> SlideLayout | None: ...

class SlideMaster:
    @property
    def part(self) -> str: ...
    @property
    def slide_layouts(self) -> SlideLayouts: ...

class SlideMasters:
    def __len__(self) -> int: ...
    def __getitem__(self, idx: int) -> SlideMaster: ...
    def __iter__(self) -> Iterator[SlideMaster]: ...

class Presentation:
    _lib: object
    _handle: int | None

    def __init__(self, path: str | None = None) -> None: ...
    @classmethod
    def new(cls, title: str) -> Presentation: ...
    def execute(
        self, op: str, payload: dict[str, object] | None = None
    ) -> dict[str, object]: ...
    def execute_batch(
        self, commands: list[BatchCommand], *, stop_on_error: bool = False
    ) -> list[BatchItemResult]: ...
    @property
    def slide_count(self) -> int: ...
    @property
    def metadata(self) -> PresentationMetadata: ...
    @property
    def slides(self) -> list[Slide]: ...
    @property
    def slides_metadata(self) -> list[SlideMetadata]: ...
    @property
    def sections(self) -> list[Section]: ...
    @property
    def slide_masters(self) -> SlideMasters: ...
    def add_slide(
        self,
        title: str,
        layout: str | None = None,
        bullets: list[str] | None = None,
    ) -> Slide: ...
    def remove_slide(self, index: int) -> None: ...
    def move_slide(self, from_index: int, to_index: int) -> None: ...
    def duplicate_slide(self, index: int, insert_at: int | None = None) -> int: ...
    def update_slide(
        self,
        index: int,
        title: str | None = None,
        layout: str | None = None,
        bullets: list[str] | None = None,
    ) -> None: ...
    def add_chart(
        self,
        slide_index: int,
        chart_type: str,
        categories: list[str],
        values_or_series: list[float] | list[dict[str, str | list[float]]],
        **kwargs: str | tuple[float, float, float, float],
    ) -> int: ...
    def add_table(
        self,
        slide_index: int,
        rows: int,
        cols: int,
        bounds: tuple[int, int, int, int],
    ) -> int: ...
    def get_table(self, slide_index: int, shape_id: int) -> TableInfo: ...
    def set_table_flags(
        self, slide_index: int, shape_id: int, flags: dict[str, bool]
    ) -> None: ...
    def set_table_cell_text(
        self, slide_index: int, shape_id: int, row: int, col: int, text: str
    ) -> None: ...
    def get_table_cell(
        self, slide_index: int, shape_id: int, row: int, col: int
    ) -> TableCellInfo: ...
    def merge_table_cells(
        self, slide_index: int, shape_id: int, cell_range: tuple[int, int, int, int]
    ) -> None: ...
    def split_table_cell(
        self, slide_index: int, shape_id: int, row: int, col: int
    ) -> None: ...
    def set_slide_title(self, index: int, title: str) -> None: ...
    def merge_from_file(self, path: str) -> None: ...
    def find_and_replace(self, find_text: str, replace_text: str) -> int: ...
    def search_shapes(
        self, query: ShapeSearchQuery | str
    ) -> list[ShapeSearchResult]: ...
    def get_authors(self) -> list[Author]: ...
    def add_author(self, name: str, initials: str) -> int: ...
    def get_comments(self, slide_index: int) -> list[Comment]: ...
    def add_comment(
        self, slide_index: int, author_id: int, text: str, x: int = 0, y: int = 0
    ) -> int: ...
    def remove_comment(
        self,
        slide_index_or_index: int,
        author_id: int | None = None,
        author_index: int | None = None,
    ) -> None: ...
    def add_section(self, name: str, slide_indices: list[int]) -> None: ...
    def remove_section(self, name: str) -> None: ...
    def rename_section(self, old_name: str, new_name: str) -> None: ...
    @property
    def core_properties(self) -> CoreProperties: ...
    @core_properties.setter
    def core_properties(self, props: CoreProperties) -> None: ...
    @property
    def title(self) -> str: ...
    @title.setter
    def title(self, value: str) -> None: ...
    def add_title_slide(self, title: str) -> Slide: ...
    def add_bullet_slide(self, title: str, bullets: list[str]) -> Slide: ...
    def __getitem__(self, index: int | slice) -> Slide | list[Slide]: ...
    def __len__(self) -> int: ...
    def __iter__(self) -> Iterator[Slide]: ...
    def apply_theme(self, theme_name: str) -> None: ...
    def set_slide_size(self, width: int, height: int) -> None: ...
    def list_slide_layouts(self) -> list[SlideLayoutInfo]: ...
    def rebind_slide_layout(self, slide_index: int, layout_part: str) -> None: ...
    def clone_layout_master_family(
        self, layout_part: str
    ) -> SlideMasterCloneResult: ...
    def list_shapes(self, slide_index: int) -> list[Shape]: ...
    def add_shape(
        self,
        slide_index: int,
        shape_type: str,
        bounds: tuple[float, float, float, float],
        **kwargs: str | ShapeProps,
    ) -> int: ...
    def add_image(
        self,
        slide_index: int,
        source: str | bytes,
        bounds: tuple[float, float, float, float],
        *,
        name: str = "",
        crop: ImageCrop | None = None,
        rotation: float | None = None,
        flip_h: bool | None = None,
        flip_v: bool | None = None,
        **kwargs: object,
    ) -> int: ...
    def add_video(
        self,
        slide_index: int,
        source: str | bytes,
        bounds: tuple[float, float, float, float],
        *,
        name: str = "",
        poster_frame: str | bytes | None = None,
        **kwargs: object,
    ) -> int: ...
    def add_ole_object(
        self,
        slide_index: int,
        source: str | bytes,
        bounds: tuple[float, float, float, float],
        *,
        name: str = "",
        prog_id: str = "",
        icon: str | bytes | None = None,
        **kwargs: object,
    ) -> int: ...
    def get_image_metadata(
        self,
        slide_index: int,
        shape_id: int,
    ) -> ImageMetadata: ...
    def remove_shape(self, slide_index: int, shape_id: int) -> None: ...
    def update_shape(
        self, slide_index: int, shape_id: int, updates: ShapeUpdate
    ) -> None: ...
    def get_notes(self, slide_index: int) -> str: ...
    def set_notes(self, slide_index: int, text: str) -> None: ...
    def list_slide_charts(self, slide_index: int) -> list[SlideChartRef]: ...
    def update_chart_data(
        self,
        slide_index: int,
        chart_selector: ChartSelector | list[str],
        data: ChartDataUpdate | list[dict[str, object]],
    ) -> None: ...
    def open(self, path: str) -> None: ...
    def save(self, path: str) -> None: ...
    def close(self) -> None: ...
    def __enter__(self) -> Self: ...
    def __exit__(
        self,
        exc_type: type[BaseException] | None,
        exc_val: BaseException | None,
        exc_tb: TracebackType | None,
    ) -> None: ...
